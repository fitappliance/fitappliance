{
  "name": "fitappliance-v2",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "node scripts/generate-brand-pages.js && node scripts/generate-comparisons.js && node scripts/generate-guides.js && node scripts/generate-sitemap.js",
    "test": "node --test tests/*.test.mjs",
    "sync": "node scripts/sync.js && node scripts/split-appliances.js",
    "sync-verify": "npm run sync && npm run generate-comparisons && npm run verify-compare-quality",
    "split-data": "node scripts/split-appliances.js",
    "add-swing": "node scripts/add-door-swing.js",
    "suggest-swing": "node scripts/suggest-door-swing.js",
    "infer-swing": "node scripts/infer-door-swing.js",
    "bulk-import": "node scripts/bulk-import.js",
    "research-sheet": "node scripts/generate-research-sheet.js",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "generate-cavity": "node scripts/generate-cavity-pages.js",
    "generate-doorway": "node scripts/generate-doorway-pages.js",
    "generate-guides": "node scripts/generate-guides.js",
    "generate-comparisons": "node scripts/generate-comparisons.js",
    "generate-og-images": "node scripts/generate-og-images.js",
    "generate-image-sitemap": "node scripts/generate-image-sitemap.js",
    "generate-rss": "node scripts/generate-rss.js",
    "generate-pages": "node scripts/generate-brand-pages.js && node scripts/generate-comparisons.js",
    "generate-all": "npm run generate-pages && npm run generate-cavity && npm run generate-doorway && npm run generate-guides && npm run generate-sitemap && npm run generate-og-images && npm run generate-image-sitemap && npm run generate-rss && npm run build-link-graph && npm run validate-schema",
    "promo-kit": "node scripts/generate-promotion-kit.js",
    "build-link-graph": "node scripts/build-link-graph.js",
    "validate-schema": "node scripts/validate-schema.js",
    "lighthouse-ci": "node scripts/lighthouse-ci.js",
    "ping-indexnow": "node scripts/ping-indexnow.js",
    "audit-compare-links": "node scripts/audit-compare-links.js",
    "audit-link-quality": "node scripts/audit-link-quality.js",
    "verify-compare-quality": "node scripts/verify-compare-quality.js",
    "lint": "node --check scripts/*.js scripts/sources/*.js scripts/utils/*.js tests/*.test.mjs && sh -c 'for f in public/scripts/ui/*.js; do node --input-type=module --check < \"$f\"; done'"
  },
  "devDependencies": {
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^13.1.0",
    "sharp": "^0.34.5"
  }
}
