{
  "name": "fitappliance-v2",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "sync": "node scripts/sync.js && node scripts/split-appliances.js",
    "split-data": "node scripts/split-appliances.js",
    "add-swing": "node scripts/add-door-swing.js",
    "suggest-swing": "node scripts/suggest-door-swing.js",
    "infer-swing": "node scripts/infer-door-swing.js",
    "bulk-import": "node scripts/bulk-import.js",
    "research-sheet": "node scripts/generate-research-sheet.js",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "generate-comparisons": "node scripts/generate-comparisons.js",
    "generate-pages": "node scripts/generate-brand-pages.js && node scripts/generate-comparisons.js && node scripts/generate-sitemap.js",
    "promo-kit": "node scripts/generate-promotion-kit.js",
    "lint": "node --check scripts/*.js scripts/sources/*.js scripts/utils/*.js tests/*.test.mjs && sh -c 'for f in public/scripts/ui/*.js; do node --input-type=module --check < \"$f\"; done'"
  }
}
