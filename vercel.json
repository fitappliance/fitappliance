{
  "version": 2,
  "name": "fitappliance",
  "regions": ["syd1"],
  "rewrites": [
    { "source": "/google32758d7798f4a670.html", "destination": "/google32758d7798f4a670.html" },
    { "source": "/google5keGnUyvuq31_mxZ9pNVPIsh7BzKBbM7aHdxUTZZDJM.html", "destination": "/google5keGnUyvuq31_mxZ9pNVPIsh7BzKBbM7aHdxUTZZDJM.html" },
    { "source": "/data/:path*",          "destination": "/public/data/:path*" },
    { "source": "/scripts/:path*",       "destination": "/public/scripts/:path*" },
    { "source": "/icons/:path*",         "destination": "/public/icons/:path*" },
    { "source": "/manifest.webmanifest", "destination": "/public/manifest.webmanifest" },
    { "source": "/service-worker.js",    "destination": "/public/service-worker.js" },
    { "source": "/ads.txt",              "destination": "/public/ads.txt" },
    { "source": "/sitemap.xml",          "destination": "/public/sitemap.xml" },
    { "source": "/rss.xml",              "destination": "/public/rss.xml" },
    { "source": "/image-sitemap.xml",    "destination": "/public/image-sitemap.xml" },
    { "source": "/a8f09a8f55a15e62d93ec6b5ca1397b4.txt", "destination": "/public/a8f09a8f55a15e62d93ec6b5ca1397b4.txt" },
    { "source": "/og-images/:path*",     "destination": "/public/og-images/:path*" },
    { "source": "/robots.txt",           "destination": "/public/robots.txt" },
    { "source": "/affiliate-disclosure", "destination": "/pages/affiliate-disclosure.html" },
    { "source": "/privacy-policy",       "destination": "/pages/privacy-policy.html" },
    { "source": "/subscribe",            "destination": "/pages/subscribe.html" },
    { "source": "/methodology",          "destination": "/pages/methodology.html" },
    { "source": "/about/editorial-standards", "destination": "/pages/about/editorial-standards.html" },
    { "source": "/brands/:slug",         "destination": "/pages/brands/:slug.html" },
    { "source": "/compare/:slug",        "destination": "/pages/compare/:slug.html" },
    { "source": "/cavity/:slug",         "destination": "/pages/cavity/:slug.html" },
    { "source": "/doorway/:slug",        "destination": "/pages/doorway/:slug.html" },
    { "source": "/location/:city/:category", "destination": "/pages/location/:city/:category.html" },
    { "source": "/tools/:slug",          "destination": "/pages/tools/:slug.html" },
    { "source": "/guides/:slug",         "destination": "/pages/guides/:slug.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",     "value": "geolocation=(), camera=(), microphone=()" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/data/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/public/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    }
  ]
}
