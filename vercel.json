{
  "version": 2,
  "name": "fitappliance",
  "buildCommand": "npm run build",
  "cleanUrls": true,
  "trailingSlash": false,
  "regions": ["syd1"],
  "redirects": [
    {
      "source": "/compare/euro-vs-robinhood-dryer-clearance",
      "destination": "/brands/euro-dryer-clearance",
      "permanent": true
    },
    {
      "source": "/compare/smeg-vs-miele-dishwasher-clearance",
      "destination": "/compare/fisher-paykel-vs-miele-dishwasher-clearance",
      "permanent": true
    },
    {
      "source": "/location/canberra",
      "destination": "/location/canberra/fridge",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/google32758d7798f4a670.html", "destination": "/google32758d7798f4a670.html" },
    { "source": "/google5keGnUyvuq31_mxZ9pNVPIsh7BzKBbM7aHdxUTZZDJM.html", "destination": "/google5keGnUyvuq31_mxZ9pNVPIsh7BzKBbM7aHdxUTZZDJM.html" },
    { "source": "/data/:path*",          "destination": "/public/data/:path*" },
    { "source": "/pdf-evidence/:path*",  "destination": "/data/pdf-evidence/:path*" },
    { "source": "/scripts/:path*",       "destination": "/public/scripts/:path*" },
    { "source": "/icons/:path*",         "destination": "/public/icons/:path*" },
    { "source": "/manifest.webmanifest", "destination": "/public/manifest.webmanifest" },
    { "source": "/service-worker.js",    "destination": "/public/service-worker.js" },
    { "source": "/styles.css",           "destination": "/public/styles.css" },
    { "source": "/styles-deferred.css",  "destination": "/public/styles-deferred.css" },
    { "source": "/ads.txt",              "destination": "/public/ads.txt" },
    { "source": "/sitemap.xml",          "destination": "/public/sitemap.xml" },
    { "source": "/rss.xml",              "destination": "/public/rss.xml" },
    { "source": "/image-sitemap.xml",    "destination": "/public/image-sitemap.xml" },
    { "source": "/a8f09a8f55a15e62d93ec6b5ca1397b4.txt", "destination": "/public/a8f09a8f55a15e62d93ec6b5ca1397b4.txt" },
    { "source": "/og-images/:path*",     "destination": "/public/og-images/:path*" },
    { "source": "/robots.txt",           "destination": "/public/robots.txt" },
    { "source": "/affiliate-disclosure", "destination": "/pages/affiliate-disclosure" },
    { "source": "/privacy",            "destination": "/pages/privacy" },
    { "source": "/privacy-policy",       "destination": "/pages/privacy-policy" },
    { "source": "/terms",              "destination": "/pages/terms" },
    { "source": "/contact",            "destination": "/pages/contact" },
    { "source": "/subscribe",            "destination": "/pages/subscribe" },
    { "source": "/account",              "destination": "/pages/account" },
    { "source": "/about",                "destination": "/pages/about" },
    { "source": "/methodology",          "destination": "/pages/methodology" },
    { "source": "/about/editorial-standards", "destination": "/pages/about/editorial-standards" },
    { "source": "/products",            "destination": "/pages/products" },
    { "source": "/products/:slug",       "destination": "/pages/products/:slug" },
    { "source": "/brands/:slug",         "destination": "/pages/brands/:slug" },
    { "source": "/compare/:slug",        "destination": "/pages/compare/:slug" },
    { "source": "/cavity/:slug",         "destination": "/pages/cavity/:slug" },
    { "source": "/doorway/:slug",        "destination": "/pages/doorway/:slug" },
    { "source": "/fit-check/:slug",      "destination": "/pages/fit-check/:slug" },
    { "source": "/location/:city/:category", "destination": "/pages/location/:city/:category" },
    { "source": "/tools/:slug",          "destination": "/pages/tools/:slug" },
    { "source": "/guides/:slug",         "destination": "/pages/guides/:slug" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://i.ytimg.com; font-src 'self' data:; frame-src https://www.youtube-nocookie.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
        },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",     "value": "geolocation=(), camera=(), microphone=()" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/data/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/pdf-evidence/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/og-images/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/icons/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/scripts/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/styles-deferred.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/public/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    }
  ]
}
